{
	"name": "@obp/shared",
	"version": "1.2.1",
	"description": "Shared components and utilities for Open Bank Project frontend apps",
	"author": {
		"name": "Open Bank Project",
		"url": "https://www.openbankproject.com/"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./src/lib/index.ts",
	"types": "./src/lib/index.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/lib/index.ts",
			"svelte": "./src/lib/index.ts"
		},
		"./components": {
			"types": "./src/lib/components/index.ts",
			"svelte": "./src/lib/components/index.ts"
		},
		"./opey": {
			"types": "./src/lib/opey/index.ts",
			"svelte": "./src/lib/opey/index.ts"
		},
		"./obp": {
			"types": "./src/lib/obp/index.ts",
			"svelte": "./src/lib/obp/index.ts"
		},
		"./utils": {
			"types": "./src/lib/utils/index.ts",
			"svelte": "./src/lib/utils/index.ts"
		},
		"./stores": {
			"types": "./src/lib/stores/index.ts",
			"svelte": "./src/lib/stores/index.ts"
		},
		"./health-check": {
			"types": "./src/lib/health-check/index.ts",
			"svelte": "./src/lib/health-check/index.ts"
		},
		"./markdown": {
			"types": "./src/lib/markdown/index.ts",
			"svelte": "./src/lib/markdown/index.ts"
		},
		"./config": {
			"types": "./src/lib/config/index.ts",
			"svelte": "./src/lib/config/index.ts"
		},
		"./server": {
			"types": "./src/lib/server/index.ts",
			"default": "./src/lib/server/index.ts"
		},
		"./server/oauth": {
			"types": "./src/lib/server/oauth/index.ts",
			"default": "./src/lib/server/oauth/index.ts"
		},
		"./server/redis": {
			"types": "./src/lib/server/redis/index.ts",
			"default": "./src/lib/server/redis/index.ts"
		},
		"./server/health-check": {
			"types": "./src/lib/server/health-check/index.ts",
			"default": "./src/lib/server/health-check/index.ts"
		},
		"./server/obp": {
			"types": "./src/lib/server/obp/index.ts",
			"default": "./src/lib/server/obp/index.ts"
		},
		"./server/opey": {
			"types": "./src/lib/server/opey/index.ts",
			"default": "./src/lib/server/opey/index.ts"
		}
	},
	"dependencies": {
		"@lucide/svelte": "^0.513.0",
		"@skeletonlabs/skeleton": "^4.0.0",
		"@skeletonlabs/skeleton-svelte": "^4.0.0",
		"arctic": "^3.7.0",
		"bits-ui": "^2.8.10",
		"ioredis": "^5.6.1",
		"jwt-decode": "^4.0.0",
		"markdown-it": "^14.1.0",
		"prismjs": "^1.30.0",
		"svelte-kit-connect-redis": "^0.1.0",
		"svelte-kit-sessions": "^0.4.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.49.1",
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.4",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.4.0",
		"@types/prismjs": "^1.26.5",
		"dotenv": "^17.2.1",
		"jsdom": "^26.0.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.2.6",
		"vitest": "^3.0.0"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"keywords": [
		"svelte",
		"components",
		"openbankproject"
	]
}
